{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/market/will-:team-win-the-2026-fifa-world-cup",
      "has": [
        {
          "type": "host",
          "value": "wc26chances.com"
        }
      ],
      "destination": "https://www.wc26chances.com/teams/:team",
      "statusCode": 308
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "wc26chances.com"
        }
      ],
      "destination": "https://www.wc26chances.com/:path*",
      "statusCode": 308
    }
  ]
}
